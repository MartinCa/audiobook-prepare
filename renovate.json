{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "minimumReleaseAge": "4 days",
  "regexManagers": [
    {
      "fileMatch": ["^Dockerfile$"],
      "matchStrings": [
        "ARG MP4V2_URL=\"https://github\\.com/enzo1982/mp4v2/archive/refs/tags/v(?<currentValue>[\\d.]+)\\.zip\""
      ],
      "depNameTemplate": "enzo1982/mp4v2",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "fileMatch": ["^Dockerfile$"],
      "matchStrings": ["ARG FDK_AAC_VERSION=(?<currentValue>[\\d.]+)"],
      "depNameTemplate": "mstorsjo/fdk-aac",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "fileMatch": ["^Dockerfile$"],
      "matchStrings": [
        "wget https://github\\.com/nu774/fdkaac/archive/v(?<currentValue>[\\d.]+)\\.tar\\.gz"
      ],
      "depNameTemplate": "nu774/fdkaac",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "fileMatch": ["^Dockerfile$"],
      "matchStrings": ["ARG OPENJPEG_VERSION=(?<currentValue>[\\d.]+)"],
      "depNameTemplate": "uclouvain/openjpeg",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "fileMatch": ["^Dockerfile$"],
      "matchStrings": ["ARG OPUS_VERSION=(?<currentValue>[\\d.]+)"],
      "depNameTemplate": "xiph/opus",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "fileMatch": ["^Dockerfile$"],
      "matchStrings": ["ARG LIBSHINE_VERSION=(?<currentValue>[\\d.]+)"],
      "depNameTemplate": "toots/shine",
      "datasourceTemplate": "github-releases"
    },
    {
      "fileMatch": ["^Dockerfile$"],
      "matchStrings": ["ARG SPEEX_VERSION=(?<currentValue>[\\d.]+)"],
      "depNameTemplate": "xiph/speex",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^Speex-(?<version>.+)$"
    },
    {
      "fileMatch": ["^Dockerfile$"],
      "matchStrings": ["ARG OGG_VERSION=(?<currentValue>[\\d.]+)"],
      "depNameTemplate": "xiph/ogg",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "fileMatch": ["^Dockerfile$"],
      "matchStrings": ["ARG THEORA_VERSION=(?<currentValue>[\\d.]+)"],
      "depNameTemplate": "xiph/theora",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "fileMatch": ["^Dockerfile$"],
      "matchStrings": ["ARG TWOLAME_VERSION=(?<currentValue>[\\d.]+)"],
      "depNameTemplate": "njh/twolame",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "fileMatch": ["^Dockerfile$"],
      "matchStrings": ["ARG VORBIS_VERSION=(?<currentValue>[\\d.]+)"],
      "depNameTemplate": "xiph/vorbis",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "fileMatch": ["^Dockerfile$"],
      "matchStrings": ["ARG LIBWEBP_VERSION=(?<currentValue>[\\d.]+)"],
      "depNameTemplate": "webmproject/libwebp",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "fileMatch": ["^Dockerfile$"],
      "matchStrings": ["ARG FFMPEG_VERSION=(?<currentValue>[\\d.]+)"],
      "depNameTemplate": "FFmpeg/FFmpeg",
      "datasourceTemplate": "github-tags",
      "extractVersionTemplate": "^n(?<version>.+)$"
    }
  ]
}
